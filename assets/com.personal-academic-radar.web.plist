<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.personal-academic-radar.web</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PROJECT_ROOT__/.venv/bin/academic-radar</string>
    <string>web</string>
    <string>--config</string><string>__STATE_DIR__/config.toml</string>
    <string>--port</string><string>8765</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>__STATE_DIR__/web.stdout.log</string>
  <key>StandardErrorPath</key><string>__STATE_DIR__/web.stderr.log</string>
</dict>
</plist>
